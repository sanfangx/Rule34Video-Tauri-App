{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rule34Video",
  "version": "1.0.4",
  "identifier": "com.rule34video.tauri",
  "build": {
    "devUrl": "https://rule34video.com",
    "frontendDist": "https://rule34video.com"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "rule34video"
        ]
      }
    }
  }
}
